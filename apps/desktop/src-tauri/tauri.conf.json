{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Draft Team App",
  "version": "0.1.0",
  "identifier": "com.draftteam.app",
  "build": {
    "beforeDevCommand": "npm --workspace @draft-team-app/desktop run dev",
    "beforeBuildCommand": "npm --workspace @draft-team-app/desktop run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Draft Team App",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
